# 网站标题
VITE_APP_TITLE = Shiguang-Cover

# 网站的ICP备案号码（选填），footer 中展示备案信息，例如：豫ICP备2025XXXXXXX号
VITE_APP_ICP_NUMBER =

# 全局字体名称（选填），不填写则使用浏览器默认字体
# 可用字体：MaokenZhuyuanTi(猫啃珠圆体)、HarmonyOS_Regular(鸿蒙字体)、
#           yozai(悠哉字体)、寒蝉全圆体、Douyin Sans(抖音美好体)、Microsoft YaHei(微软雅黑)
VITE_APP_FONT_FAMILY =

# 全局字体 CSS 文件地址（选填），配合 VITE_APP_FONT_FAMILY 使用
# 设置后页面加载时会自动引入该字体样式表
# 例如：https://chinese-fonts-cdn.deno.dev/packages/mkzyt/dist/猫啃珠圆体/result.css
VITE_APP_FONT_CSS_URL =

# Umami 统计脚本地址（选填），不填写则不加载统计脚本，例如：https://umami.example.com/script.js
VITE_UMAMI_SCRIPT_URL =

# Umami 网站 ID（选填），例如：xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_UMAMI_WEBSITE_ID =
